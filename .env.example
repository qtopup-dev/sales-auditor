# Database
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=root
DB_NAME=alejinput_db

# Prisma CLI (used by prisma migrate dev — must include ?timezone=UTC)
DATABASE_URL="mysql://${DB_USER}:${DB_PASSWORD}@${DB_HOST}:${DB_PORT}/${DB_NAME}?timezone=UTC"

# Express
PORT=3001
NODE_ENV=development
# IMPORTANT: Replace with 32+ random bytes hex string before production
SESSION_SECRET=change-me-before-production-use-openssl-rand-hex-32

# Frontend URL (for CORS)
CLIENT_ORIGIN=http://localhost:5173
